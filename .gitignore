# --- SENSITIVE DATA (Never push these!) ---
.env
.env.*
*.pem
*.key
serviceAccountKey.json
secrets.json

# --- DEPENDENCIES ---
# These are large and can be re-installed using package managers
node_modules/
bower_components/
vendor/

# --- BUILD OUTPUTS ---
# These are generated from your source code
dist/
build/
out/
.next/
.nuxt/
.cache/
.vite/

# --- OS SPECIFIC ---
# System-generated files that differ by machine
.DS_Store
Thumbs.db
desktop.ini
.AppleDouble
.LSOverride

# --- IDE & EDITORS ---
# Personal editor settings that shouldn't be forced on others
.vscode/
.idea/
*.swp
*.swo
.project
.classpath
.settings/

# --- LOGS & DIAGNOSTICS ---
# Temporary files used for debugging
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.stylelintcache

# --- TESTING ---
# Generated reports and coverage data
coverage/
.nyc_output/
